   "# Nouveau layout pour toute la chanson\n",
   "\n",
   "\n",
   "lastTick = -1\n",
   "direction = 0\n",
   "\n",
   "pos = [1,0,0]\n",
   "\n",
   "for tick in data.index:\n",
   "           \n",
   "    tickDiff = tick - lastTick\n",
   "    layout = Layout2(nbt = nbtfile)\n",
   "    layout.tick = lastTick\n",
   "    \n",
   "    # Supprmier index Sol si necessaire\n",
   "    layout.index_floor = nbtfile.get_index_safe(\"dark_oak_planks\")\n",
   "\n",
   "    notesEntier = data.loc[tick]['note entier']\n",
   "    notesDemi = data.loc[tick]['note demi']\n",
   "    #print(pos[0], pos[2])\n",
   "\n",
   "    layout.pos[0] = pos[0]\n",
   "    layout.pos[2] = pos[2]\n",
   "    layout.data.pos[0] = pos[0]\n",
   "    layout.data.pos[2] = pos[2]\n",
   "\n",
   "    if(direction%4 == 0):\n",
   "            \n",
   "        layout.add(tickDiff, notesEntier,notesDemi,True)\n",
   "        pos[0]+=1\n",
   "        pos[2]+=-2\n",
   "    elif(direction%4 == 1):\n",
   "\n",
   "        layout.add(tickDiff, notesEntier,notesDemi)\n",
   "        layout.flip()\n",
   "        layout.rotate(-1)\n",
   "        pos[0]+=2\n",
   "        pos[2]+=-1\n",
   "    elif(direction%4 == 2):\n",
   "\n",
   "        layout.add(tickDiff, notesEntier,notesDemi,True)\n",
   "        layout.flip()\n",
   "        pos[0]+=1\n",
   "        pos[2]+=2\n",
   "\n",
   "    else:\n",
   "        layout.add(tickDiff, notesEntier,notesDemi)\n",
   "        layout.rotate(1)        \n",
   "        pos[0]+=2\n",
   "        pos[2]+=1\n",
   "\n",
   "    direction+=1\n",
   "\n",
   "    dataNBT.add_data(layout.data)\n",
   "\n",
   "    lastTick = tick\n",
   "    #print(lastTick)\n",
   "    #lastTick = tickEntier\n",
   "\n"
  ]
